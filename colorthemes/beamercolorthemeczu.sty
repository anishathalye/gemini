% Gemini theme
% https://github.com/anishathalye/gemini
% University of Life Sciences Prague variation
% V.S.

% ====================
% Definitions
% ====================

\definecolor{lightgray}{RGB}{245, 246, 250}
\definecolor{teal}{RGB}{0, 170, 160}        % #00aaa0 - primary university color
\definecolor{darkteal}{RGB}{0, 120, 113}    % darker shade for accents/rules
\definecolor{lightteal}{RGB}{224, 247, 246} % very light tint for block backgrounds

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=darkteal,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=darkteal}

% Headline
\setbeamercolor{headline}{fg=white,bg=teal}
\setbeamercolor{headline rule}{bg=darkteal}

% Block
\setbeamercolor{block title}{fg=teal,bg=white}
\setbeamercolor{block separator}{bg=teal}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block title alerted}{fg=darkteal,bg=lightteal}
\setbeamercolor{block separator alerted}{bg=darkteal}
\setbeamercolor{block body alerted}{fg=black,bg=lightteal}

% Example Block
\setbeamercolor{block title example}{fg=darkteal,bg=lightgray}
\setbeamercolor{block separator example}{bg=teal}
\setbeamercolor{block body example}{fg=black,bg=lightgray}

% Heading
\setbeamercolor{heading}{fg=darkteal}

% Itemize
\setbeamercolor{item}{fg=teal}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
