% Gemini theme
% https://github.com/anishathalye/gemini
%
% IITGN (Indian Institute of Technology Gandhinagar) color theme
% Contributed by Pappala Sai Keerthana & Ravi Bhavana
% Used for poster presented at IIT Gandhinagar UG Research Showcase 2026

% ====================
% Definitions
% ====================

\definecolor{iitgnblue}{HTML}{003366}
\definecolor{lightiitblue}{HTML}{F2F7FD}
\definecolor{midiitblue}{HTML}{E3EEF9}
\definecolor{deepiitblue}{HTML}{D6E6F6}
\definecolor{iitgnwhite}{HTML}{FFFFFF}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=iitgnwhite}
\setbeamercolor{palette secondary}{fg=black,bg=iitgnwhite}
\setbeamercolor{palette tertiary}{bg=iitgnblue,fg=iitgnwhite}
\setbeamercolor{palette quaternary}{fg=black,bg=iitgnwhite}
\setbeamercolor{structure}{fg=iitgnblue}

% Headline
\setbeamercolor{headline}{fg=iitgnwhite,bg=iitgnblue}
\setbeamercolor{headline rule}{bg=deepiitblue}

% Block
\setbeamercolor{block title}{fg=iitgnblue,bg=iitgnwhite}
\setbeamercolor{block separator}{bg=iitgnblue}
\setbeamercolor{block body}{fg=black,bg=iitgnwhite}

% Alert Block
\setbeamercolor{block title alerted}{fg=iitgnblue,bg=lightiitblue}
\setbeamercolor{block separator alerted}{bg=iitgnblue}
\setbeamercolor{block body alerted}{fg=black,bg=lightiitblue}

% Example Block
\setbeamercolor{block title example}{fg=iitgnblue,bg=midiitblue}
\setbeamercolor{block separator example}{bg=iitgnblue}
\setbeamercolor{block body example}{fg=black,bg=midiitblue}

% Heading
\setbeamercolor{heading}{fg=iitgnblue}

% Itemize
\setbeamercolor{item}{fg=iitgnblue}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
